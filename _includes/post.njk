---
layout: base.njk
extraCss: |
  /* ─── ARTICLE PAGE ─── */
  .post-hero {
    background: var(--dark);
    padding: 5rem 2rem 4rem;
    border-bottom: 1px solid var(--border);
  }
  .post-back {
    font-family: var(--font-cond);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 2rem;
    transition: color 0.2s;
  }
  .post-back:hover { color: var(--white); }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-bottom: 1.2rem;
    flex-wrap: wrap;
  }
  .post-date {
    font-family: var(--font-cond);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .post-author {
    font-family: var(--font-cond);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .post-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 4rem);
    letter-spacing: 0.03em;
    line-height: 1;
    color: var(--white);
    margin-bottom: 1rem;
  }
  .post-excerpt {
    font-size: 1.1rem;
    color: var(--muted);
    max-width: 680px;
    line-height: 1.6;
  }
  .post-body {
    padding: 4rem 2rem;
    max-width: 780px;
    margin: 0 auto;
  }
  .post-content h2 {
    font-family: var(--font-display);
    font-size: 2rem;
    letter-spacing: 0.03em;
    color: var(--white);
    margin: 2.5rem 0 1rem;
  }
  .post-content h3 {
    font-family: var(--font-cond);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 2rem 0 0.75rem;
  }
  .post-content p {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--white);
    opacity: 0.9;
    margin-bottom: 1.25rem;
  }
  .post-content ul, .post-content ol {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .post-content li {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--white);
    opacity: 0.9;
    margin-bottom: 0.4rem;
  }
  .post-content strong { color: var(--white); font-weight: 600; }
  .post-content em { font-style: italic; }
  .post-content a { color: var(--accent); text-decoration: underline; }
  .post-content a:hover { color: var(--accent2); }
  .post-content blockquote {
    border-left: 3px solid var(--accent);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: var(--dark2);
  }
  .post-content blockquote p { margin: 0; font-style: italic; }
  .post-content hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }
  .post-content img {
    max-width: 100%;
    height: auto;
    margin: 1.5rem 0;
    border: 1px solid var(--border);
  }
  .post-footer {
    max-width: 780px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
    border-top: 1px solid var(--border);
    padding-top: 2.5rem;
  }
  .post-footer a {
    font-family: var(--font-cond);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    transition: color 0.2s;
  }
  .post-footer a:hover { color: var(--accent2); }
---

<section class="post-hero">
  <div class="container">
    <a href="/blog/" class="post-back">← Tous les articles</a>
    <div class="post-meta">
      <span class="post-date">{{ date | readableDate }}</span>
      {% if author %}<span class="post-author">Par {{ author }}</span>{% endif %}
    </div>
    <h1>{{ title | upper }}</h1>
    {% if excerpt %}<p class="post-excerpt">{{ excerpt }}</p>{% endif %}
  </div>
</section>

<article class="post-body">
  <div class="post-content">
    {{ content | safe }}
  </div>
</article>

<div class="post-footer">
  <a href="/blog/">← Retour aux articles</a>
</div>
